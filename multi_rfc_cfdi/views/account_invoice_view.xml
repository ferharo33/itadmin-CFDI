<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_inherit_form" model="ir.ui.view">
            <field name="name">account.move.multi.rfc.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">
               <xpath expr="//field[@name='invoice_payment_term_id']" position="after">
                   <field name="custom_company_id" attrs="{'readonly': [('estado_factura','!=','factura_no_generada')]}"/>
               </xpath>
            </field>
    </record>
