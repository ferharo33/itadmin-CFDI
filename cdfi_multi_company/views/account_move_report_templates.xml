<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="cfdi_external_layout_inherit" inherit_id="cdfi_invoice.cfdi_external_layout">
        <xpath expr="//t[@t-set='company']" position="replace">
            <t t-set="company" t-value="(o.cfdi_emitter_company_id or o.company_id)"></t>
        </xpath>
    </template>

    <template id="report_invoice_document_inherit" inherit_id="cdfi_invoice.report_invoice_document">
        <xpath expr="//t[@t-set='o' and @t-value=&quot;o.with_context({'lang':o.partner_id.lang})&quot;]" position="after">
            <t t-set="cfdi_company" t-value="o.cfdi_emitter_company_id or o.company_id"/>
        </xpath>
        <xpath expr="//img[@t-if='o.company_id.logo']" position="attributes">
            <attribute name="t-if">cfdi_company.logo</attribute>
            <attribute name="t-att-src">'data:image/png;base64,%s' % to_text(cfdi_company.logo)</attribute>
        </xpath>
        <xpath expr="//span[@t-field='o.company_id.nombre_fiscal']" position="attributes">
            <attribute name="t-field">cfdi_company.nombre_fiscal</attribute>
        </xpath>
        <xpath expr="//span[@t-field='o.company_id.partner_id.name']" position="attributes">
            <attribute name="t-field">cfdi_company.partner_id.name</attribute>
        </xpath>
        <xpath expr="//span[@t-field='o.company_id.vat']" position="attributes">
            <attribute name="t-field">cfdi_company.vat</attribute>
        </xpath>
        <xpath expr="//span[@t-field='o.company_id.regimen_fiscal']" position="attributes">
            <attribute name="t-field">cfdi_company.regimen_fiscal</attribute>
        </xpath>
        <xpath expr="//span[@t-if='o.company_id.serie_factura']" position="attributes">
            <attribute name="t-if">cfdi_company.serie_factura</attribute>
            <attribute name="t-field">cfdi_company.serie_factura</attribute>
        </xpath>
        <xpath expr="//span[@t-field='o.company_id.partner_id.zip']" position="attributes">
            <attribute name="t-field">cfdi_company.partner_id.zip</attribute>
        </xpath>
        <xpath expr="//div[@t-if='o.company_id.modo_prueba == True']" position="attributes">
            <attribute name="t-if">cfdi_company.modo_prueba == True</attribute>
        </xpath>
    </template>
</odoo>
